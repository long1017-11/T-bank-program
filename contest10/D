#include <bits/stdc++.h>
using namespace std;

struct Event {
    int x, y1, y2, type;
    bool operator<(const Event& other) const {
        if (x != other.x) return x < other.x;
        return type > other.type; // +1 раньше -1
    }
};

struct Node {
    int mx, add;
};

vector<Node> tree;
vector<int> ys;

void push(int v) {
    if (tree[v].add != 0) {
        for (int u : {v*2, v*2+1}) {
            tree[u].mx += tree[v].add;
            tree[u].add += tree[v].add;
        }
        tree[v].add = 0;
    }
}

void update(int v, int tl, int tr, int l, int r, int val) {
    if (l > r) return;
    if (l == tl && r == tr) {
        tree[v].mx += val;
        tree[v].add += val;
        return;
    }
    push(v);
    int tm = (tl + tr) / 2;
    update(v*2, tl, tm, l, min(r, tm), val);
    update(v*2+1, tm+1, tr, max(l, tm+1), r, val);
    tree[v].mx = max(tree[v*2].mx, tree[v*2+1].mx);
}

int query() {
    return tree[1].mx;
}

int find_pos(int v, int tl, int tr) {
    if (tl == tr) return tl;
    push(v);
    int tm = (tl + tr) / 2;
    if (tree[v*2].mx >= tree[v*2+1].mx)
        return find_pos(v*2, tl, tm);
    else
        return find_pos(v*2+1, tm+1, tr);
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;

    vector<Event> events;
    ys.reserve(2*n);

    for (int i = 0; i < n; i++) {
        int x1, y1, x2, y2;
        cin >> x1 >> y1 >> x2 >> y2;

        // важно: y1 сверху, y2 снизу
        events.push_back({x1, y1, y2, +1});
        events.push_back({x2, y1, y2, -1});

        ys.push_back(y1);
        ys.push_back(y2);
    }

    // сжатие координат
    sort(ys.begin(), ys.end());
    ys.erase(unique(ys.begin(), ys.end()), ys.end());

    auto getY = [&](int y) {
        return lower_bound(ys.begin(), ys.end(), y) - ys.begin();
    };

    int m = ys.size();
    tree.assign(4*m, {0, 0});

    sort(events.begin(), events.end());

    int best = 0, best_x = 0, best_y = 0;

    for (auto &e : events) {
        int l = getY(e.y1);
        int r = getY(e.y2);

        update(1, 0, m-1, l, r, e.type);

        int cur = query();
        if (cur > best) {
            best = cur;
            best_x = e.x;
            int pos = find_pos(1, 0, m-1);
            best_y = ys[pos];
        }
    }

    cout << best << "\n";
    cout << best_x << " " << best_y << "\n";
}

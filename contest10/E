#include <bits/stdc++.h>
using namespace std;

using ll = long long;

struct Fenwick {
    int n;
    vector<int> t;
    Fenwick(int n): n(n), t(n+1, 0) {}

    void add(int i, int v) {
        for (++i; i <= n; i += i & -i) t[i] += v;
    }

    int sum(int i) {
        int s = 0;
        for (++i; i > 0; i -= i & -i) s += t[i];
        return s;
    }

    int query(int l, int r) {
        return sum(r) - sum(l-1);
    }
};

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;

    map<ll, vector<pair<ll,ll>>> hor, ver;

    for (int i = 0; i < n; i++) {
        ll x1, y1, x2, y2;
        cin >> x1 >> y1 >> x2 >> y2;

        if (y1 == y2) {
            if (x1 > x2) swap(x1, x2);
            hor[y1].push_back({x1, x2});
        } else {
            if (y1 > y2) swap(y1, y2);
            ver[x1].push_back({y1, y2});
        }
    }

    // --- объединение горизонтальных
    ll total_h = 0;
    vector<tuple<ll,ll,ll>> h_segments;

    for (auto &[y, vec]: hor) {
        sort(vec.begin(), vec.end());
        ll l = vec[0].first, r = vec[0].second;

        for (auto &[x1, x2]: vec) {
            if (x1 <= r) {
                r = max(r, x2);
            } else {
                total_h += r - l + 1;
                h_segments.emplace_back(l, r, y);
                l = x1;
                r = x2;
            }
        }
        total_h += r - l + 1;
        h_segments.emplace_back(l, r, y);
    }

    // --- объединение вертикальных
    ll total_v = 0;
    vector<tuple<ll,ll,ll>> v_segments;

    for (auto &[x, vec]: ver) {
        sort(vec.begin(), vec.end());
        ll l = vec[0].first, r = vec[0].second;

        for (auto &[y1, y2]: vec) {
            if (y1 <= r) {
                r = max(r, y2);
            } else {
                total_v += r - l + 1;
                v_segments.emplace_back(x, l, r);
                l = y1;
                r = y2;
            }
        }
        total_v += r - l + 1;
        v_segments.emplace_back(x, l, r);
    }

    // --- подготовка координат y
    vector<ll> ys;
    for (auto &[l, r, y]: h_segments) ys.push_back(y);
    for (auto &[x, l, r]: v_segments) {
        ys.push_back(l);
        ys.push_back(r);
    }

    sort(ys.begin(), ys.end());
    ys.erase(unique(ys.begin(), ys.end()), ys.end());

    auto getY = [&](ll y) {
        return lower_bound(ys.begin(), ys.end(), y) - ys.begin();
    };

    // --- события
    struct Event {
        ll x;
        int type; // 0 add, 1 remove, 2 query
        ll y1, y2;
    };

    vector<Event> events;

    for (auto &[l, r, y]: h_segments) {
        events.push_back({l, 0, y, 0});
        events.push_back({r+1, 1, y, 0});
    }

    for (auto &[x, y1, y2]: v_segments) {
        events.push_back({x, 2, y1, y2});
    }

    sort(events.begin(), events.end(), [](auto &a, auto &b){
        if (a.x != b.x) return a.x < b.x;
        return a.type < b.type;
    });

    Fenwick bit(ys.size());

    ll intersections = 0;

    for (auto &e: events) {
        if (e.type == 0) {
            bit.add(getY(e.y1), 1);
        } else if (e.type == 1) {
            bit.add(getY(e.y1), -1);
        } else {
            int l = getY(e.y1);
            int r = getY(e.y2);
            intersections += bit.query(l, r);
        }
    }

    cout << total_h + total_v - intersections << "\n";
}
